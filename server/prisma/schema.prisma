generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  USER
  VENDOR
  MODERATOR
  FINANCE
  ADMIN
}

enum StaffPermissionKey {
  VIEW_DASHBOARD
  MANAGE_USERS
  REVIEW_VENDORS
  MANAGE_FINANCE
  MODERATE_CONTENT
  REVIEW_RISK
  MANAGE_CATALOG
  MANAGE_SETTINGS
  VIEW_AUDIT_LOGS
  EXPORT_DATA
  MANAGE_STAFF
}

enum RestrictionType {
  CALL
  CHAT
  GIFT
  WITHDRAWAL
}

enum UserStatus {
  ACTIVE
  SUSPENDED
  BANNED
  DELETED
}

enum VendorStatus {
  DRAFT
  SUBMITTED
  UNDER_REVIEW
  MORE_INFO
  APPROVED
  REJECTED
  SUSPENDED
  BANNED
}

enum PaymentGateway {
  BKASH
  NAGAD
  STRIPE
  SSLCOMMERZ
}

enum PaymentStatus {
  SUBMITTED
  UNDER_REVIEW
  APPROVED
  REJECTED
  CANCELLED
  REFUNDED
  PARTIALLY_REFUNDED
  DISPUTED
  CHARGEBACK
}

enum LedgerType {
  DEPOSIT
  PACKAGE_PURCHASE
  GIFT_PURCHASE
  GIFT_RECEIVED
  CALL_CHARGE
  CHAT_CHARGE
  VENDOR_EARNING
  PLATFORM_COMMISSION
  WITHDRAWAL
  WITHDRAWAL_FEE
  ADMIN_ADJUSTMENT
  PROMOTIONAL_BONUS
  REFUND
  RESERVE
  RELEASE
}

enum Direction {
  CREDIT
  DEBIT
}

enum PackageType {
  VOICE
  VIDEO
  CHAT
  COMBINATION
  SUBSCRIPTION
}

enum CallType {
  VOICE
  VIDEO
}

enum CallStatus {
  REQUESTED
  RINGING
  ACCEPTED
  REJECTED
  CANCELLED
  CONNECTING
  ACTIVE
  COMPLETED
  FAILED
  MISSED
  DISCONNECTED
  TERMINATED
  PAYMENT_FAILED
}

enum WithdrawalStatus {
  PENDING
  UNDER_REVIEW
  APPROVED
  PROCESSING
  COMPLETED
  REJECTED
  CANCELLED
  FAILED
  REVERSED
}

enum EarningStatus {
  PENDING
  AVAILABLE
  HELD
  REFUNDED
}

enum ReportStatus {
  OPEN
  UNDER_REVIEW
  RESOLVED
  REJECTED
}

enum OtpPurpose {
  REGISTER
  LOGIN
  RESET_PASSWORD
}

enum GiftCardStatus {
  ACTIVE
  PARTIALLY_USED
  FULLY_USED
  EXPIRED
  CANCELLED
  REFUNDED
  SUSPENDED
}

enum MessageType {
  TEXT
  IMAGE
  VOICE
  VIDEO
  GIFT
  SYSTEM
}

enum MessageStatus {
  SENT
  DELIVERED
  READ
  DELETED
  BLOCKED
}

enum ConnectionStatus {
  PENDING
  ACCEPTED
  REJECTED
  CANCELLED
}

model User {
  id                 String          @id @default(uuid())
  phone              String          @unique
  email              String?         @unique
  passwordHash       String
  role               Role            @default(USER)
  status             UserStatus      @default(ACTIVE)
  phoneVerifiedAt    DateTime?
  emailVerifiedAt    DateTime?
  dateOfBirth        DateTime
  termsAcceptedAt    DateTime?
  lastLoginAt        DateTime?
  deletedAt          DateTime?
  refreshTokenHash   String?
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt
  profile            Profile?
  wallet             Wallet?
  vendor             VendorProfile?
  payments           Payment[]
  userPackages       UserPackage[]
  withdrawals        Withdrawal[]
  reportsMade        Report[]        @relation("Reporter")
  reportsReceived    Report[]        @relation("Reported")
  sessions           DeviceSession[]
  notifications      Notification[]
  blocksMade         Block[]         @relation("Blocker")
  blocksReceived     Block[]         @relation("Blocked")
  conversationsOne   Conversation[]  @relation("ConversationOne")
  conversationsTwo   Conversation[]  @relation("ConversationTwo")
  sentMessages       Message[]       @relation("MessageSender")
  receivedMessages   Message[]       @relation("MessageReceiver")
  messageReactions   MessageReaction[]
  hiddenMessages     MessageHidden[]
  purchasedGiftCards UserGiftCard[]  @relation("GiftPurchaser")
  receivedGiftCards  UserGiftCard[]  @relation("GiftRecipient")
  following          Follow[]        @relation("Follower")
  followers          Follow[]        @relation("Following")
  connectionsSent    Connection[]    @relation("ConnectionRequester")
  connectionsReceived Connection[]   @relation("ConnectionRecipient")
  reviewsMade        Review[]        @relation("ReviewAuthor")
  files              FileAsset[]
  loginAttempts      LoginAttempt[]
  supportTickets     SupportTicket[] @relation("SupportRequester")
  assignedTickets    SupportTicket[] @relation("SupportAssignee")
  supportMessages    SupportMessage[]
  authIdentities     AuthIdentity[]
  reviewReports      ReviewReport[]
  pushTokens         PushToken[]
  notificationPreference NotificationPreference?
  referralCode       ReferralCode?
  referralAsReferred Referral?       @relation("ReferredUser")
  referralsMade      Referral[]      @relation("ReferrerUser")
  subscriptions      UserSubscription[]
  liveSessions       LiveSession[]
  liveViewerEvents   LiveViewerEvent[]
  dailyRewardClaims  DailyRewardClaim[]
}

model AuthIdentity {
  id             String   @id @default(uuid())
  userId         String
  provider       String
  providerUserId String
  email          String?
  createdAt      DateTime @default(now())
  lastUsedAt     DateTime @default(now())
  user           User     @relation(fields:[userId],references:[id],onDelete:Cascade)

  @@unique([provider,providerUserId])
  @@index([userId])
}

model OAuthNonce {
  id        String   @id @default(uuid())
  hash      String   @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime @default(now())

  @@index([expiresAt,usedAt])
}

model EmailCode {
  id         String   @id @default(uuid())
  email      String
  purpose    String
  codeHash   String
  attempts   Int      @default(0)
  expiresAt  DateTime
  consumedAt DateTime?
  createdAt  DateTime @default(now())

  @@index([email, purpose, createdAt])
  @@index([expiresAt, consumedAt])
}

model SupportTicket {
  id           String   @id @default(uuid())
  userId       String
  assignedToId String?
  subject      String
  category     String
  priority     String   @default("NORMAL")
  status       String   @default("OPEN")
  lastReplyAt  DateTime @default(now())
  resolvedAt   DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  user         User     @relation("SupportRequester",fields:[userId],references:[id],onDelete:Cascade)
  assignedTo   User?    @relation("SupportAssignee",fields:[assignedToId],references:[id],onDelete:SetNull)
  messages     SupportMessage[]

  @@index([userId,createdAt])
  @@index([status,priority,lastReplyAt])
}

model SupportMessage {
  id         String   @id @default(uuid())
  ticketId   String
  senderId   String
  body       String
  evidenceIds String[] @default([])
  internal   Boolean  @default(false)
  createdAt  DateTime @default(now())
  ticket     SupportTicket @relation(fields:[ticketId],references:[id],onDelete:Cascade)
  sender     User     @relation(fields:[senderId],references:[id],onDelete:Cascade)

  @@index([ticketId,createdAt])
}

model LoginAttempt {
  id         String   @id @default(uuid())
  userId     String?
  phoneHash  String
  successful Boolean
  riskLevel  String   @default("LOW")
  reason     String?
  ipAddress  String?
  userAgent  String?
  deviceId   String?
  createdAt  DateTime @default(now())
  user       User?    @relation(fields:[userId],references:[id],onDelete:SetNull)

  @@index([phoneHash,createdAt])
  @@index([userId,createdAt])
  @@index([ipAddress,createdAt])
}

model Profile {
  id          String   @id @default(uuid())
  userId      String   @unique
  username    String   @unique
  displayName String
  bio         String?  @db.VarChar(500)
  avatarUrl   String?
  coverUrl    String?
  gender      String?
  city        String?
  country     String   @default("Bangladesh")
  languages   String[]
  interests   String[]
  purpose     String?
  occupation  String?
  education   String?
  hobbies     String[]  @default([])
  online      Boolean  @default(false)
  lastSeenAt  DateTime?
  isVerified  Boolean  @default(false)
  hideOnline  Boolean  @default(false)
  hideLastSeen Boolean @default(false)
  hideAge     Boolean  @default(false)
  hideLocation Boolean @default(false)
  discoverable Boolean @default(true)
  messagesFromEveryone Boolean @default(true)
  callsFromEveryone Boolean @default(true)
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VendorProfile {
  id                 String        @id @default(uuid())
  userId             String        @unique
  status             VendorStatus  @default(DRAFT)
  legalName          String?
  address            String?
  contactEmail       String?
  profileDescription String?
  supportedLanguages String[]      @default([])
  preferredWorkingHours String?
  payoutMethod       String?
  payoutAccountEncrypted String?
  payoutAccountLast4 String?
  nidNumber          String?
  nidFrontUrl        String?
  nidBackUrl         String?
  selfieUrl          String?
  identityProvider   String?
  identityInquiryId  String?       @unique
  identityStatus     String?
  identityUpdatedAt  DateTime?
  commissionPercent  Int           @default(60)
  voiceRatePerMinute Int           @default(20)
  videoRatePerMinute Int           @default(40)
  voiceCallEnabled   Boolean       @default(true)
  videoCallEnabled   Boolean       @default(false)
  paidChatRate       Int           @default(2)
  availableForCall   Boolean       @default(false)
  breakActive        Boolean       @default(false)
  autoAcceptCalls    Boolean       @default(false)
  maximumDailyCalls  Int?
  minimumCallerBalance Int         @default(0)
  averageRating      Decimal       @default(0) @db.Decimal(3, 2)
  approvedAt         DateTime?
  user               User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  calls              CallSession[]
  earnings           Earning[]
  reviews            Review[]
  schedules          VendorSchedule[]
}

model VendorSchedule {
  id          String   @id @default(uuid())
  vendorId    String
  dayOfWeek   Int
  startMinute Int
  endMinute   Int
  timezone    String   @default("Asia/Dhaka")
  enabled     Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  vendor      VendorProfile @relation(fields:[vendorId],references:[id],onDelete:Cascade)

  @@unique([vendorId,dayOfWeek])
  @@index([vendorId,enabled])
}

model Wallet {
  id               String         @id @default(uuid())
  userId           String         @unique
  currency         String         @default("BDT")
  purchased        Int            @default(0)
  promotional      Int            @default(0)
  reserved         Int            @default(0)
  pendingEarning   Int            @default(0)
  availableEarning Int            @default(0)
  held             Int            @default(0)
  version          Int            @default(0)
  user             User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  ledgers          WalletLedger[]
}

model WalletLedger {
  id             String     @id @default(uuid())
  walletId       String
  userId         String
  type           LedgerType
  direction      Direction
  amount         Int
  balanceBefore  Int
  balanceAfter   Int
  referenceType  String
  referenceId    String
  description    String
  idempotencyKey String     @unique
  metadata       Json?
  createdAt      DateTime   @default(now())
  wallet         Wallet     @relation(fields: [walletId], references: [id])

  @@index([userId, createdAt])
}

model PlatformLedger {
  id             String   @id @default(uuid())
  type           String
  amount         Int
  currency       String   @default("BDT")
  referenceType  String
  referenceId    String
  description    String
  idempotencyKey String   @unique
  metadata       Json?
  createdAt      DateTime @default(now())

  @@index([type, createdAt])
  @@index([referenceType, referenceId])
}

model Payment {
  id              String         @id @default(uuid())
  userId          String
  gateway         PaymentGateway
  receiverNumber  String?
  senderNumber    String?
  transactionId   String
  orderReference  String?        @unique
  gatewayIntentId String?        @unique
  amount          Int
  currencyAmountMinor Int        @default(0)
  conversionMinorPerPoint Int     @default(100)
  currency        String         @default("BDT")
  status          PaymentStatus  @default(SUBMITTED)
  rejectionReason String?
  reviewedBy      String?
  reviewedAt      DateTime?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  user            User           @relation(fields: [userId], references: [id])
  webhooks         PaymentWebhook[]
  refunds          PaymentRefund[]
  reconciliations  PaymentReconciliation[]
  disputes          PaymentDispute[]

  @@unique([gateway, transactionId])
  @@index([status, createdAt])
}

model PaymentDispute {
  id               String   @id @default(uuid())
  paymentId        String
  gatewayDisputeId String   @unique
  amount           Int
  currency         String
  reason           String?
  status           String
  evidenceDueAt    DateTime?
  resolvedAt       DateTime?
  metadata         Json?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  payment          Payment  @relation(fields:[paymentId],references:[id],onDelete:Cascade)

  @@index([status,createdAt])
  @@index([paymentId,createdAt])
}

model PaymentWebhook {
  id          String         @id @default(uuid())
  gateway     PaymentGateway
  eventId     String
  eventType   String
  paymentId   String?
  payload     Json
  processedAt DateTime?
  error       String?
  createdAt   DateTime       @default(now())
  payment     Payment?       @relation(fields: [paymentId], references: [id])

  @@unique([gateway, eventId])
  @@index([processedAt, createdAt])
}

model PaymentRefund {
  id                String   @id @default(uuid())
  paymentId         String
  amount            Int
  reason            String
  status            String   @default("PENDING")
  gatewayRefundId   String?  @unique
  idempotencyKey    String   @unique
  requestedBy       String
  processedAt       DateTime?
  error             String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  payment           Payment  @relation(fields: [paymentId], references: [id])

  @@index([paymentId, status])
}

model PaymentReconciliation {
  id             String   @id @default(uuid())
  paymentId      String
  gatewayStatus  String
  localStatus    String
  amountMatches  Boolean
  statusMatches  Boolean
  discrepancy    String?
  checkedAt      DateTime @default(now())
  payment        Payment  @relation(fields: [paymentId], references: [id])

  @@index([checkedAt, discrepancy])
}

model Package {
  id           String        @id @default(uuid())
  name         String
  type         PackageType
  price        Int
  points       Int           @default(0)
  voiceSeconds Int           @default(0)
  videoSeconds Int           @default(0)
  messageCount Int           @default(0)
  validityDays Int
  active       Boolean       @default(true)
  createdAt    DateTime      @default(now())
  purchases    UserPackage[]
}

model UserPackage {
  id                    String   @id @default(uuid())
  userId                String
  packageId             String
  remainingVoiceSeconds Int
  remainingVideoSeconds Int    @default(0)
  remainingMessages     Int
  expiresAt             DateTime
  active                Boolean  @default(true)
  user                  User     @relation(fields: [userId], references: [id])
  package               Package  @relation(fields: [packageId], references: [id])
}

model CallSession {
  id              String        @id @default(uuid())
  callerId        String
  vendorId        String
  callType        CallType     @default(VOICE)
  status          CallStatus    @default(REQUESTED)
  ratePerMinute   Int
  reservedAmount  Int
  prepaidSeconds  Int           @default(0)
  paymentSourceType String      @default("WALLET")
  paymentSourceId String?
  connectedAt     DateTime?
  lastHeartbeatAt DateTime?
  lastHeartbeatSeconds Int      @default(0)
  endedAt         DateTime?
  durationSeconds Int           @default(0)
  billedSeconds   Int           @default(0)
  grossAmount     Int           @default(0)
  vendorAmount    Int           @default(0)
  platformAmount  Int           @default(0)
  provider        String        @default("AGORA")
  providerSessionId String?
  endedBy         String?
  disconnectReason String?
  disputeStatus   String        @default("NONE")
  idempotencyKey  String        @unique
  createdAt       DateTime      @default(now())
  vendor          VendorProfile @relation(fields: [vendorId], references: [id])
  earning         Earning?
  review          Review?
  participantEvents CallParticipantEvent[]

  @@index([status, lastHeartbeatAt])
}

model CallParticipantEvent {
  id        String   @id @default(uuid())
  callId    String
  userId    String
  eventType String
  eventTime DateTime @default(now())
  metadata  Json?
  createdAt DateTime @default(now())
  call      CallSession @relation(fields:[callId],references:[id],onDelete:Cascade)

  @@index([callId,eventTime])
  @@index([userId,eventTime])
}

model Review {
  id              String        @id @default(uuid())
  reviewerId      String
  vendorId        String
  callId          String        @unique
  rating          Int
  behaviourRating Int
  qualityRating   Int
  comment         String?       @db.VarChar(1000)
  status          String        @default("VISIBLE")
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  reviewer        User          @relation("ReviewAuthor", fields: [reviewerId], references: [id])
  vendor          VendorProfile @relation(fields: [vendorId], references: [id])
  call            CallSession   @relation(fields: [callId], references: [id])
  reports         ReviewReport[]

  @@index([vendorId, status, createdAt])
}

model ReviewReport {
  id         String   @id @default(uuid())
  reviewId   String
  reporterId String
  reason     String
  details    String?
  status     String   @default("OPEN")
  resolution String?
  reviewedBy String?
  reviewedAt DateTime?
  createdAt  DateTime @default(now())
  review     Review   @relation(fields:[reviewId],references:[id],onDelete:Cascade)
  reporter   User     @relation(fields:[reporterId],references:[id],onDelete:Cascade)

  @@unique([reviewId,reporterId])
  @@index([status,createdAt])
}

model Earning {
  id             String        @id @default(uuid())
  vendorId       String
  callId         String?       @unique
  sourceType     String
  sourceId       String
  grossAmount    Int
  vendorAmount   Int
  platformAmount Int
  status         EarningStatus @default(PENDING)
  availableAt    DateTime
  createdAt      DateTime      @default(now())
  vendor         VendorProfile @relation(fields: [vendorId], references: [id])
  call           CallSession?  @relation(fields: [callId], references: [id])

  @@index([status, availableAt])
}

model DigitalGift {
  id            String  @id @default(uuid())
  name          String
  iconUrl       String
  animationUrl  String?
  category      String  @default("STANDARD")
  pointPrice    Int
  vendorPercent Int     @default(60)
  active        Boolean @default(true)
  enabledInCalls Boolean @default(true)
  enabledInChats Boolean @default(true)
  displayOrder  Int     @default(0)
  transactions GiftTransaction[]
}

model GiftTransaction {
  id             String   @id @default(uuid())
  giftId         String
  senderId       String
  receiverId     String
  callId         String?
  conversationId String?
  grossAmount    Int
  vendorAmount   Int
  platformAmount Int
  status         String   @default("COMPLETED")
  idempotencyKey String   @unique
  createdAt      DateTime @default(now())
  gift           DigitalGift @relation(fields:[giftId],references:[id])

  @@index([receiverId,createdAt])
  @@index([senderId,createdAt])
  @@index([callId,createdAt])
  @@index([conversationId,createdAt])
}

model Withdrawal {
  id              String           @id @default(uuid())
  userId          String
  amount          Int
  fee             Int              @default(0)
  method          PaymentGateway
  accountDetailsEncrypted String @map("accountNumber")
  accountLast4    String?
  status          WithdrawalStatus @default(PENDING)
  rejectionReason String?
  idempotencyKey  String           @unique
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  user            User             @relation(fields: [userId], references: [id])
}

model Report {
  id             String       @id @default(uuid())
  reporterId     String
  reportedUserId String
  category       String
  description    String
  evidenceUrls   String[]     @default([])
  priority       String       @default("NORMAL")
  assignedModeratorId String?
  resolution     String?
  resolvedAt     DateTime?
  status         ReportStatus @default(OPEN)
  createdAt      DateTime     @default(now())
  reporter       User         @relation("Reporter", fields: [reporterId], references: [id])
  reported       User         @relation("Reported", fields: [reportedUserId], references: [id])
}

model BlockedTerm {
  id          String   @id @default(uuid())
  term        String   @unique
  category    String
  severity    String   @default("BLOCK")
  active      Boolean  @default(true)
  createdBy   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model ModerationEvent {
  id          String   @id @default(uuid())
  userId      String
  entityType  String
  entityId    String?
  category    String
  severity    String
  matchedText String?
  action      String
  metadata    Json?
  createdAt   DateTime @default(now())

  @@index([userId, createdAt])
  @@index([category, createdAt])
}

model ModerationAppeal {
  id          String   @id @default(uuid())
  userId      String
  targetType  String
  targetId    String?
  reason      String
  status      String   @default("OPEN")
  resolution  String?
  reviewedBy  String?
  reviewedAt  DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([userId, createdAt])
  @@index([status, createdAt])
}

model UserRestriction {
  id         String          @id @default(uuid())
  userId     String
  type       RestrictionType
  reason     String
  sourceType String
  sourceId   String
  appliedBy  String?
  expiresAt  DateTime?
  revokedAt  DateTime?
  revokedBy  String?
  createdAt  DateTime        @default(now())

  @@unique([sourceType,sourceId,type])
  @@index([userId,type,expiresAt,revokedAt])
}

model FileAsset {
  id           String   @id @default(uuid())
  ownerId      String
  category     String
  storageKey   String   @unique
  originalName String
  mimeType     String
  sizeBytes    Int
  visibility   String   @default("PRIVATE")
  status       String   @default("PENDING")
  checksum     String?
  scanProvider String?
  scanResult   String?
  scanAttempts Int      @default(0)
  scannedAt    DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  owner        User     @relation(fields: [ownerId], references: [id], onDelete: Cascade)

  @@index([ownerId, category, createdAt])
}

model OtpCode {
  id         String     @id @default(uuid())
  phone      String
  purpose    OtpPurpose
  codeHash   String
  attempts   Int        @default(0)
  expiresAt  DateTime
  consumedAt DateTime?
  createdAt  DateTime   @default(now())

  @@index([phone, purpose, createdAt])
}

model DeviceSession {
  id               String    @id @default(uuid())
  userId           String
  refreshTokenHash String
  deviceId         String
  deviceName       String?
  platform         String?
  ipAddress        String?
  userAgent        String?
  lastUsedAt       DateTime  @default(now())
  revokedAt        DateTime?
  createdAt        DateTime  @default(now())
  user             User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, deviceId])
}

model Setting {
  key         String   @id
  value       Json
  description String?
  updatedBy   String?
  updatedAt   DateTime @updatedAt
}

model AuditLog {
  id         String   @id @default(uuid())
  actorId    String?
  actorRole  String?
  action     String
  entityType String
  entityId   String?
  oldValue   Json?
  newValue   Json?
  ipAddress  String?
  userAgent  String?
  createdAt  DateTime @default(now())

  @@index([entityType, entityId, createdAt])
}

model StaffPermission {
  id         String             @id @default(uuid())
  userId     String
  permission StaffPermissionKey
  allowed    Boolean
  grantedBy  String
  reason     String?
  createdAt  DateTime           @default(now())
  updatedAt  DateTime           @updatedAt

  @@unique([userId, permission])
  @@index([userId, allowed])
}

model Block {
  id            String   @id @default(uuid())
  blockerId     String
  blockedUserId String
  reason        String?
  createdAt     DateTime @default(now())
  blocker       User     @relation("Blocker", fields: [blockerId], references: [id], onDelete: Cascade)
  blocked       User     @relation("Blocked", fields: [blockedUserId], references: [id], onDelete: Cascade)

  @@unique([blockerId, blockedUserId])
}

model Follow {
  id          String   @id @default(uuid())
  followerId  String
  followingId String
  createdAt   DateTime @default(now())
  follower    User     @relation("Follower", fields: [followerId], references: [id], onDelete: Cascade)
  following   User     @relation("Following", fields: [followingId], references: [id], onDelete: Cascade)

  @@unique([followerId, followingId])
  @@index([followingId, createdAt])
}

model Connection {
  id          String           @id @default(uuid())
  requesterId String
  recipientId String
  status      ConnectionStatus @default(PENDING)
  respondedAt DateTime?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  requester   User             @relation("ConnectionRequester", fields: [requesterId], references: [id], onDelete: Cascade)
  recipient   User             @relation("ConnectionRecipient", fields: [recipientId], references: [id], onDelete: Cascade)

  @@unique([requesterId, recipientId])
  @@index([recipientId, status, createdAt])
}

model RtcWebhookEvent {
  id          String   @id @default(uuid())
  provider    String
  eventId     String
  eventType   String
  channelName String?
  payload     Json
  processedAt DateTime?
  error       String?
  createdAt   DateTime @default(now())

  @@unique([provider, eventId])
  @@index([processedAt, createdAt])
}

model IdentityWebhookEvent {
  id          String   @id @default(uuid())
  provider    String
  eventId     String
  eventType   String
  inquiryId   String?
  payload     Json
  processedAt DateTime?
  error       String?
  createdAt   DateTime @default(now())

  @@unique([provider,eventId])
  @@index([processedAt,createdAt])
}

model Conversation {
  id            String    @id @default(uuid())
  userOneId     String
  userTwoId     String
  vendorId      String?
  paidUntil     DateTime?
  active        Boolean   @default(true)
  lastMessageAt DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  userOne       User      @relation("ConversationOne", fields: [userOneId], references: [id])
  userTwo       User      @relation("ConversationTwo", fields: [userTwoId], references: [id])
  messages      Message[]

  @@unique([userOneId, userTwoId])
}

model Message {
  id             String        @id @default(uuid())
  conversationId String
  senderId       String
  receiverId     String
  type           MessageType   @default(TEXT)
  content        String?
  attachmentUrl  String?
  replyToId      String?
  pointCost      Int           @default(0)
  vendorAmount   Int           @default(0)
  platformAmount Int           @default(0)
  status         MessageStatus @default(SENT)
  readAt         DateTime?
  deletedAt      DateTime?
  idempotencyKey String        @unique
  createdAt      DateTime      @default(now())
  conversation   Conversation  @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender         User          @relation("MessageSender", fields: [senderId], references: [id])
  receiver       User          @relation("MessageReceiver", fields: [receiverId], references: [id])
  reactions      MessageReaction[]
  hiddenFor      MessageHidden[]

  @@index([conversationId, createdAt])
}

model MessageReaction {
  id        String   @id @default(uuid())
  messageId String
  userId    String
  emoji     String
  createdAt DateTime @default(now())
  message   Message  @relation(fields: [messageId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([messageId, userId])
  @@index([messageId])
}

model MessageHidden {
  messageId String
  userId    String
  hiddenAt  DateTime @default(now())
  message   Message  @relation(fields: [messageId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([messageId, userId])
}

model GiftCard {
  id             String         @id @default(uuid())
  name           String
  type           PackageType
  price          Int
  voiceSeconds   Int            @default(0)
  videoSeconds   Int            @default(0)
  messageCount   Int            @default(0)
  validityDays   Int
  transferable   Boolean        @default(false)
  vendorSpecific Boolean        @default(false)
  active         Boolean        @default(true)
  createdAt      DateTime       @default(now())
  owned          UserGiftCard[]
}

model UserGiftCard {
  id                    String         @id @default(uuid())
  giftCardId            String
  purchaserId           String
  recipientId           String
  vendorId              String?
  remainingVoiceSeconds Int            @default(0)
  remainingVideoSeconds Int            @default(0)
  remainingMessages     Int            @default(0)
  status                GiftCardStatus @default(ACTIVE)
  activatedAt           DateTime?
  expiresAt             DateTime
  createdAt             DateTime       @default(now())
  giftCard              GiftCard       @relation(fields: [giftCardId], references: [id])
  purchaser             User           @relation("GiftPurchaser", fields: [purchaserId], references: [id])
  recipient             User           @relation("GiftRecipient", fields: [recipientId], references: [id])
}

model Notification {
  id        String    @id @default(uuid())
  userId    String
  type      String
  title     String
  body      String
  data      Json?
  readAt    DateTime?
  dispatchedAt DateTime?
  createdAt DateTime  @default(now())
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, readAt, createdAt])
}

model PushToken {
  id         String   @id @default(uuid())
  userId     String
  deviceId   String
  token      String   @unique
  platform   String
  active     Boolean  @default(true)
  lastUsedAt DateTime @default(now())
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, deviceId])
  @@index([userId, active])
}

model NotificationPreference {
  id          String   @id @default(uuid())
  userId      String   @unique
  pushEnabled Boolean  @default(true)
  emailEnabled Boolean @default(true)
  smsSecurity Boolean  @default(true)
  mutedTypes  String[] @default([])
  quietStart  String?
  quietEnd    String?
  updatedAt   DateTime @updatedAt
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model NotificationDelivery {
  id             String   @id @default(uuid())
  notificationId String
  channel        String
  destination    String?
  status         String
  providerId     String?
  error          String?
  attemptedAt    DateTime @default(now())

  @@index([notificationId, channel])
}

model NotificationCampaign {
  id          String   @id @default(uuid())
  title       String
  body        String
  type        String
  audience    Json
  createdBy   String
  recipientCount Int
  status      String   @default("QUEUED")
  createdAt   DateTime @default(now())

  @@index([createdAt])
}

model FraudAssessment {
  id         String   @id @default(uuid())
  userId     String
  context    String
  referenceId String?
  score      Int
  reasons    String[]
  action     String
  metadata   Json?
  reviewedBy String?
  reviewedAt DateTime?
  resolution String?
  createdAt  DateTime @default(now())

  @@index([userId, createdAt])
  @@index([action, createdAt])
}

model MembershipPlan {
  id           String   @id @default(uuid())
  name         String   @unique
  description  String
  price        Int
  currency     String   @default("BDT")
  durationDays Int
  benefits     Json
  badge        String?
  displayOrder Int      @default(0)
  active       Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  subscriptions UserSubscription[]
}

model UserSubscription {
  id        String   @id @default(uuid())
  userId    String
  planId    String
  status    String   @default("ACTIVE")
  startsAt  DateTime @default(now())
  expiresAt DateTime
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  plan      MembershipPlan @relation(fields: [planId], references: [id])

  @@index([userId, status, expiresAt])
}

model ReferralCode {
  id        String   @id @default(uuid())
  userId    String   @unique
  code      String   @unique
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  referrals Referral[]
}

model Referral {
  id             String   @id @default(uuid())
  referralCodeId String
  referrerId     String
  referredUserId String   @unique
  status         String   @default("PENDING_PAYMENT")
  qualifiedAt    DateTime?
  createdAt      DateTime @default(now())
  code           ReferralCode @relation(fields: [referralCodeId], references: [id])
  referrer       User     @relation("ReferrerUser", fields: [referrerId], references: [id])
  referred       User     @relation("ReferredUser", fields: [referredUserId], references: [id])
  rewards        ReferralReward[]

  @@index([referrerId, status])
}

model ReferralReward {
  id          String   @id @default(uuid())
  referralId  String
  recipientId String
  amount      Int
  reason      String
  referenceId String
  createdAt   DateTime @default(now())
  referral    Referral @relation(fields: [referralId], references: [id])

  @@unique([referralId, recipientId, reason])
}

enum LiveStatus {
  LIVE
  ENDED
}

model LiveSession {
  id                String       @id @default(uuid())
  hostId            String
  title             String?
  status            LiveStatus   @default(LIVE)
  viewerCount       Int          @default(0)
  peakViewers       Int          @default(0)
  provider          String       @default("AGORA")
  providerSessionId String?
  startedAt         DateTime     @default(now())
  endedAt           DateTime?
  createdAt         DateTime     @default(now())
  host              User         @relation(fields: [hostId], references: [id])
  viewerEvents      LiveViewerEvent[]

  @@index([status, viewerCount])
  @@index([hostId, status])
}

model LiveViewerEvent {
  id       String      @id @default(uuid())
  liveId   String
  userId   String
  joinedAt DateTime    @default(now())
  leftAt   DateTime?
  live     LiveSession @relation(fields: [liveId], references: [id])
  user     User        @relation(fields: [userId], references: [id])

  @@index([liveId, leftAt])
  @@index([userId, leftAt])
}

model DailyRewardClaim {
  id        String   @id @default(uuid())
  userId    String
  amount    Int
  claimedAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])

  @@index([userId, claimedAt])
}
