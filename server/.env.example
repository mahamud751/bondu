NODE_ENV=development
PORT=3000
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=120
METRICS_TOKEN=
PAYOUT_ENCRYPTION_KEY=
PAYOUT_ENCRYPTION_KEY_ID=v1
DATABASE_URL=postgresql://socialconnect:socialconnect@localhost:5432/socialconnect?schema=public
REDIS_URL=redis://localhost:6379
CORS_ORIGINS=http://localhost:3001

JWT_ACCESS_SECRET=replace-with-at-least-32-random-characters
JWT_REFRESH_SECRET=replace-with-a-different-32-character-secret
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=30d

# Agora credentials are mandatory when NODE_ENV=production.
AGORA_APP_ID=
AGORA_APP_CERTIFICATE=
# Agora Notification Service customer secret and the project-specific channel-end event IDs.
AGORA_WEBHOOK_SECRET=
AGORA_END_EVENT_TYPES=
RTC_DEVELOPMENT_SECRET=replace-for-shared-development

# Local/manual Bangladesh payment collection. Production gateway adapters use separate secrets.
BKASH_RECEIVER_NUMBER=01XXXXXXXXX
NAGAD_RECEIVER_NUMBER=01XXXXXXXXX
BKASH_WEBHOOK_SECRET=
NAGAD_WEBHOOK_SECRET=
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
PUBLIC_API_URL=https://api.example.com/api/v1
MOBILE_PAYMENT_RETURN_URL=socialconnect://payment
SSLCOMMERZ_STORE_ID=
SSLCOMMERZ_STORE_PASSWORD=
SSLCOMMERZ_LIVE=false

SMS_PROVIDER=development
SMS_API_KEY=
SMS_DEFAULT_COUNTRY_CODE=+880
SMS_WEBHOOK_URL=
SMS_WEBHOOK_SECRET=
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
EMAIL_PROVIDER=disabled
EMAIL_FROM=SocialConnect <notifications@example.com>
RESEND_API_KEY=
EMAIL_WEBHOOK_URL=
EMAIL_WEBHOOK_SECRET=
GOOGLE_CLIENT_IDS=
APPLE_CLIENT_ID=
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=
PERSONA_API_KEY=
PERSONA_TEMPLATE_ID=
PERSONA_WEBHOOK_SECRET=
PERSONA_API_VERSION=2023-01-05

STORAGE_PROVIDER=local
S3_ENDPOINT=
S3_BUCKET=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
FILE_SCAN_PROVIDER=disabled
CLAMAV_HOST=localhost
CLAMAV_PORT=3310
FILE_SCAN_TIMEOUT_MS=30000

EARNING_RELEASE_INTERVAL_MS=300000
CALL_HEARTBEAT_TIMEOUT_SECONDS=45
PAYMENT_RECONCILIATION_INTERVAL_MS=86400000
BACKGROUND_QUEUE_MODE=inline
# all for local development, api/worker for separated production services.
BACKGROUND_PROCESS_ROLE=all
BACKGROUND_JOB_CONCURRENCY=4
DISABLE_BACKGROUND_JOBS=false
SEED_ADMIN_PHONE=01900000000
SEED_ADMIN_PASSWORD=Admin123!
SEED_STAFF_PASSWORD=Staff123!
